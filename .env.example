# ThreatWatch Configuration
# Copy this file to .env and customize as needed

# Site domain (used in RSS feed links)
SITE_DOMAIN=localhost:8098

# How many days of articles to keep (default: 7)
FEED_CUTOFF_DAYS=7

# HTTP server port
PORT=8098

# Optional: AI-powered briefing (works with any OpenAI-compatible provider)
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=auto

# ThreatWatch Configuration
# Copy this file to .env and customize as needed

# Optional: Claude API key for enhanced AI classification
# If not set, the free keyword-based classifier is used (recommended)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Site domain (used in RSS feed links)
SITE_DOMAIN=localhost:8098

# How many days of articles to keep (default: 7)
FEED_CUTOFF_DAYS=7

# Daily API budget in USD (only applies if using AI classifier)
DAILY_BUDGET_USD=2.00

# HTTP server port
PORT=8098
